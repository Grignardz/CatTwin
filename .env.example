# Firebase project config (from Firebase Console > Project Settings > Your apps > Web app)
# These are safe to expose client-side — they identify your Firebase project,
# they are NOT secret API keys. Actual Gemini access is authorized server-side
# by Firebase AI Logic + protected by App Check (see src/lib/firebase.ts).
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Optional: reCAPTCHA v3 site key for Firebase App Check (recommended before shipping).
VITE_RECAPTCHA_SITE_KEY=""
