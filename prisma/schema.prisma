generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String                  @id @default(uuid())
  email            String                  @unique
  passwordHash     String                  @map("password_hash")
  name             String
  avatarUrl        String?                 @map("avatar_url")
  phone            String?
  country          String?
  preferences      String                  @default("{}")
  createdAt        DateTime                @default(now()) @map("created_at")
  cats             Cat[]
  photoScans       PhotoScan[]
  chatMessages     ChatMessage[]
  notifications    Notification[]
  dismissedNotices DismissedNotification[]

  @@map("users")
}

model Cat {
  id               String             @id @default(uuid())
  userId           String             @map("user_id")
  name             String
  breed            String
  ageLabel         String?            @map("age_label")
  birthDate        DateTime?          @map("birth_date")
  avatarUrl        String?            @map("avatar_url")
  gender           String?
  currentWeightKg  Float?             @map("current_weight_kg")
  targetWeightKg   Float?             @map("target_weight_kg")
  color            String?
  environment      String?
  allergies        String?
  existingDiseases String?            @map("existing_diseases")
  medicalNotes     String?            @map("medical_notes")
  microchipId      String?            @map("microchip_id")
  neutered         String?
  createdAt        DateTime           @default(now()) @map("created_at")
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  weightLogs       WeightLog[]
  sleepLogs        SleepActivityLog[]
  waterLogs        WaterIntakeLog[]
  foodPlan         FoodPlan?
  vetRecords       VetRecord[]
  photoScans       PhotoScan[]
  healthScores     HealthScore[]
  predictions      Prediction[]
  chatMessages     ChatMessage[]
  notifications    Notification[]
  reports          Report[]

  @@index([userId])
  @@map("cats")
}

model WeightLog {
  id       String   @id @default(uuid())
  catId    String   @map("cat_id")
  weightKg Float    @map("weight_kg")
  note     String?
  loggedAt DateTime @default(now()) @map("logged_at")
  cat      Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId, loggedAt])
  @@map("weight_logs")
}

model SleepActivityLog {
  id            String   @id @default(uuid())
  catId         String   @map("cat_id")
  hoursSlept    Float    @map("hours_slept")
  activityLevel String   @map("activity_level")
  manualBcs     Int?     @map("manual_bcs")
  loggedAt      DateTime @default(now()) @map("logged_at")
  cat           Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId, loggedAt])
  @@map("sleep_activity_logs")
}

model WaterIntakeLog {
  id       String   @id @default(uuid())
  catId    String   @map("cat_id")
  amountMl Int      @map("amount_ml")
  loggedAt DateTime @default(now()) @map("logged_at")
  cat      Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId, loggedAt])
  @@map("water_intake_logs")
}

model FoodPlan {
  id          String   @id @default(uuid())
  catId       String   @unique @map("cat_id")
  mealsPerDay Int      @default(0) @map("meals_per_day")
  createdAt   DateTime @default(now()) @map("created_at")
  cat         Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  meals       Meal[]

  @@map("food_plans")
}

model Meal {
  id              String   @id @default(uuid())
  foodPlanId      String   @map("food_plan_id")
  time            String
  label           String
  foodName        String   @map("food_name")
  brand           String   @default("")
  portion         String
  reminderEnabled Boolean  @default(false) @map("reminder_enabled")
  createdAt       DateTime @default(now()) @map("created_at")
  foodPlan        FoodPlan @relation(fields: [foodPlanId], references: [id], onDelete: Cascade)

  @@map("meals")
}

model VetRecord {
  id        String    @id @default(uuid())
  catId     String    @map("cat_id")
  type      String
  name      String
  givenAt   DateTime  @map("given_at")
  dueAt     DateTime? @map("due_at")
  status    String
  note      String?
  createdAt DateTime  @default(now()) @map("created_at")
  cat       Cat       @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId, givenAt])
  @@map("vaccinations")
}

model PhotoScan {
  id                 String   @id @default(uuid())
  catId              String   @map("cat_id")
  userId             String   @map("user_id")
  photoUrl           String   @map("photo_url")
  thumbnailUrl       String   @map("thumbnail_url")
  capturedAt         DateTime @default(now()) @map("captured_at")
  bcsScore           Int?     @map("bcs_score")
  bcsConfidence      Float?   @map("bcs_confidence")
  weightEstimateKg   Float?   @map("weight_estimate_kg")
  weightConfidence   Float?   @map("weight_confidence")
  obesityRiskLevel   String?  @map("obesity_risk_level")
  coatConditionScore Int?     @map("coat_condition_score")
  coatConditionNotes String?  @map("coat_condition_notes")
  recommendations    String   @default("[]")
  overallConfidence  Float?   @map("overall_confidence")
  rawModelResponse   String?  @map("raw_model_response")
  status             String   @default("pending")
  errorMessage       String?  @map("error_message")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")
  cat                Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([catId, capturedAt(sort: Desc)])
  @@map("photo_scans")
}

model HealthScore {
  id                String   @id @default(uuid())
  catId             String   @map("cat_id")
  overallScore      Int      @map("overall_score")
  overallConfidence Int      @map("overall_confidence")
  category          String
  moduleBreakdown   String   @map("module_breakdown")
  summary           String
  timeline          String   @default("[]")
  computedAt        DateTime @default(now()) @map("computed_at")
  cat               Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId, computedAt(sort: Desc)])
  @@map("health_scores")
}

model Prediction {
  id                String   @id @default(uuid())
  catId             String   @map("cat_id")
  horizonDays       Int      @map("horizon_days")
  predictedWeightKg Float?   @map("predicted_weight_kg")
  predictedScore    Int?     @map("predicted_score")
  confidence        Int
  obesityDirection  String   @map("obesity_direction")
  weightTrend       Float?   @map("weight_trend")
  moduleForecasts   String   @map("module_forecasts")
  computedAt        DateTime @default(now()) @map("computed_at")
  cat               Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId, horizonDays, computedAt(sort: Desc)])
  @@map("predictions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  catId     String   @map("cat_id")
  userId    String   @map("user_id")
  role      String
  content   String
  actions   String   @default("[]")
  createdAt DateTime @default(now()) @map("created_at")
  cat       Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([catId, createdAt])
  @@map("chat_messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  catId     String?  @map("cat_id")
  type      String
  severity  String   @default("info")
  title     String
  body      String
  actionTo  String?  @map("action_to")
  read      Boolean  @default(false)
  dedupeKey String?  @unique @map("dedupe_key")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cat       Cat?     @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model DismissedNotification {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  notificationId String   @map("notification_id")
  createdAt      DateTime @default(now()) @map("created_at")
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationId])
  @@map("dismissed_notifications")
}

model Report {
  id               String   @id @default(uuid())
  catId            String   @map("cat_id")
  generatedAt      DateTime @default(now()) @map("generated_at")
  summaryText      String   @map("summary_text")
  includedSections String   @map("included_sections")
  dataBundle       String   @map("data_bundle")
  pdfUrl           String?  @map("pdf_url")
  cat              Cat      @relation(fields: [catId], references: [id], onDelete: Cascade)

  @@index([catId, generatedAt(sort: Desc)])
  @@map("reports")
}
